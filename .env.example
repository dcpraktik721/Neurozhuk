# Production/runtime env for Timeweb Cloud App Platform.
# NEXT_PUBLIC_* values must be available during Docker build and at runtime,
# because Next.js inlines public env values into the browser bundle.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
NEXT_PUBLIC_SITE_URL=https://neurozhuk.ru

NODE_ENV=production
PORT=3000
