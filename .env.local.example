# Supabase project URL — looks like https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon/publishable key. Both formats are accepted:
#   - Legacy JWT:   eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....
#   - Publishable:  sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
# Find both in Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical public URL used for metadata/SEO.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
